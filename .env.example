# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_secret_here

# Session - REQUIRED for production (sessions lost on restart without this)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=your_generated_secret_here

# Site domain for Twitch iframe embeds (default: localhost)
SITE_DOMAIN=localhost

# Logging level (default: INFO)
LOG_LEVEL=INFO
